#!/usr/bin/env bash
set -euo pipefail

# Ensure PATH includes common tool locations (cron uses a minimal PATH)
# Include Docker.app's bin directly so cron doesn't need to follow the symlink
export PATH="/opt/homebrew/opt/libpq/bin:/Applications/Docker.app/Contents/Resources/bin:/usr/local/bin:/opt/homebrew/bin:$PATH"

# ─── CONFIGURE: Project-specific variables ──────────────────────────────────
PROJECT_NAME="{{PROJECT_NAME}}"                     # e.g. financial-tracker
CONTAINER_NAME="{{CONTAINER_NAME}}"                 # e.g. financial_tracker_db
BOX_FOLDER="{{BOX_FOLDER}}"                         # e.g. financial-tracker
HEALTH_CHECK_TABLE="{{HEALTH_CHECK_TABLE}}"         # primary table for sanity check
MIN_DUMP_BYTES={{MIN_DUMP_BYTES:-10240}}             # recommend 5% of expected dump size
LOCAL_RETENTION_DAYS=365

# Tables to count for the .counts sidecar (space-separated)
COUNT_TABLES="{{COUNT_TABLES}}"
# e.g. "transactions vendors emails email_attachments vendor_patterns"

# Tables to checksum (subset of COUNT_TABLES, space-separated)
# Checksum SQL per table is defined in the checksum_query() function below.
CHECKSUM_TABLES="{{CHECKSUM_TABLES}}"
# e.g. "transactions vendors"

# Additional rclone copy targets: "label:local_path:box_subfolder [extra_rclone_args]"
# Leave empty array () if only backing up the database.
EXTRA_SYNC_DIRS=(
    # "cowork:$HOME/Claude-Workspace/projects/accounting:cowork --exclude gmail-expense-archive/** --exclude .~lock.* --exclude ~\$*"
    # "receipts:${PROJECT_DIR}/receipts:receipts"
    # "email-archive:${PROJECT_DIR}/data/email-archive:email-archive"
)

# Gmail alerter
ALERT_SCRIPT="$HOME/.claude/skills/backup-to-box/templates/send_alert_standalone.py"
# ─────────────────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="${SCRIPT_DIR}/.."
BACKUP_DIR="${PROJECT_DIR}/backups"
LOG_FILE="${BACKUP_DIR}/backup.log"
TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
DUMP_PREFIX="${PROJECT_NAME//-/_}"
DUMP_FILE="${BACKUP_DIR}/${DUMP_PREFIX}_${TIMESTAMP}.dump"

# Load environment (.env must provide DB credentials)
if [ -f "${PROJECT_DIR}/.env" ]; then
    set -a
    source "${PROJECT_DIR}/.env"
    set +a
else
    echo "ERROR: .env not found at ${PROJECT_DIR}/.env" >&2
    exit 1
fi

mkdir -p "${BACKUP_DIR}"

# ─── Instance locking (prevents duplicate cron races on Box OAuth) ───

LOCK_FILE="/tmp/${PROJECT_NAME}-backup.lock"
exec 9>"$LOCK_FILE"
if ! flock -n 9; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Another backup is already running — exiting." >> "${LOG_FILE}"
    exit 0
fi

# ─── Helpers ───

log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$msg" >> "${LOG_FILE}"
}

send_alert() {
    local subject="$1" body="$2"
    python3 "$ALERT_SCRIPT" "$subject" "$body" 2>> "${LOG_FILE}" || true
}

on_failure() {
    local exit_code=$?
    local last_lines
    last_lines=$(tail -10 "${LOG_FILE}" 2>/dev/null || echo "(could not read log)")
    log "=== Backup FAILED (exit code ${exit_code}) ==="
    send_alert \
        "[Mac mini] Backup FAILED — ${PROJECT_NAME}" \
        "The ${PROJECT_NAME} backup failed at $(date '+%Y-%m-%d %H:%M:%S') with exit code ${exit_code}.

Recent log:
${last_lines}"
}

trap on_failure ERR

# Run rclone copy and track success/failure.
# Usage: rclone_copy <label> <source> <dest> [extra_args...]
SYNC_FAILURES=0
rclone_copy() {
    local label="$1" src="$2" dest="$3"
    shift 3
    local rclone_log_file
    rclone_log_file=$(mktemp)
    rclone copy "$src" "$dest" "$@" --log-level NOTICE > "$rclone_log_file" 2>&1 || true
    local rc=$?
    if [ -s "$rclone_log_file" ]; then
        while IFS= read -r line; do log "  rclone: $line"; done < "$rclone_log_file"
    fi
    rm -f "$rclone_log_file"
    if [ "$rc" -ne 0 ]; then
        log "  ${label}: FAILED (exit code ${rc})"
        SYNC_FAILURES=$((SYNC_FAILURES + 1))
    else
        log "  ${label}: copied"
    fi
}

# Generate checksum SQL for a given table.
# Override this function per-project if tables have different schemas.
checksum_query() {
    local table="$1"
    case "$table" in
        transactions)
            echo "SELECT md5(sum(id)::text || '|' || count(*)::text || '|' || coalesce(sum(abs(amount)),0)::text) FROM transactions;" ;;
        vendors)
            echo "SELECT md5(sum(id)::text || '|' || count(*)::text || '|' || md5(coalesce(string_agg(name, ',' ORDER BY id), ''))) FROM vendors;" ;;
        submitted_reports)
            echo "SELECT md5(sum(id)::text || '|' || count(*)::text) FROM submitted_reports;" ;;
        persons)
            echo "SELECT md5(sum(id)::text || '|' || count(*)::text) FROM persons;" ;;
        *)
            # Generic fallback: id-based checksum
            echo "SELECT md5(sum(id)::text || '|' || count(*)::text) FROM ${table};" ;;
    esac
}

log "=== Backup started ==="

# ─── Step 0a: Ensure Docker Desktop daemon is running ───

if ! docker info > /dev/null 2>&1; then
    log "Docker daemon not running — starting Docker Desktop..."
    open -a Docker
    for i in $(seq 1 60); do
        if docker info > /dev/null 2>&1; then
            log "Docker daemon is now up."
            break
        fi
        sleep 2
    done
    if ! docker info > /dev/null 2>&1; then
        log "ERROR: Docker daemon did not start within 120 seconds."
        exit 1
    fi
fi

# ─── Step 0b: Ensure DB container is running ───

if ! docker ps --format '{{.Names}}' | grep -q "^${CONTAINER_NAME}\$"; then
    log "DB container not running — starting it..."
    docker compose -f "${PROJECT_DIR}/docker-compose.yml" up -d 2>&1 | while read -r line; do log "  docker: $line"; done
    for i in $(seq 1 30); do
        if docker exec "$CONTAINER_NAME" pg_isready -U "${POSTGRES_USER}" > /dev/null 2>&1; then
            break
        fi
        sleep 1
    done
    if ! docker exec "$CONTAINER_NAME" pg_isready -U "${POSTGRES_USER}" > /dev/null 2>&1; then
        log "ERROR: DB container failed to start within 30 seconds."
        exit 1
    fi
    log "DB container started."
fi

# ─── Step 1: Validate DB is healthy and has data ───

log "Checking database health..."

# Build dynamic count query from COUNT_TABLES
COUNT_SQL=""
for table in $COUNT_TABLES; do
    [ -n "$COUNT_SQL" ] && COUNT_SQL="${COUNT_SQL} UNION ALL "
    COUNT_SQL="${COUNT_SQL}SELECT '${table}=' || COUNT(*) FROM ${table}"
done
COUNT_SQL="${COUNT_SQL};"

ROW_COUNTS=$(docker exec -e PGPASSWORD="${POSTGRES_PASSWORD}" "$CONTAINER_NAME" \
    psql -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" -t -A -c "$COUNT_SQL" 2>&1)

HEALTH_COUNT=$(echo "$ROW_COUNTS" | grep "${HEALTH_CHECK_TABLE}=" | cut -d= -f2)

if [ -z "$HEALTH_COUNT" ] || [ "$HEALTH_COUNT" -lt 1 ]; then
    log "ERROR: ${HEALTH_CHECK_TABLE} table is empty or inaccessible. Refusing to back up an empty database."
    log "Row counts: $ROW_COUNTS"
    exit 1
fi

log "Row counts: $(echo "$ROW_COUNTS" | tr '\n' ', ')"

# ─── Step 1b: Write .counts sidecar (row counts + checksums) ───

COUNTS_FILE="${DUMP_FILE%.dump}.counts"
{
    echo "# Generated by backup.sh at $(date '+%Y-%m-%d %H:%M:%S')"
    echo "# Format: table=count [table_md5=checksum]"
    echo "$ROW_COUNTS"
    # Checksums for high-value tables
    for table in $CHECKSUM_TABLES; do
        CKSUM_SQL=$(checksum_query "$table")
        CKSUM=$(docker exec -e PGPASSWORD="${POSTGRES_PASSWORD}" "$CONTAINER_NAME" \
            psql -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" -t -A -c "$CKSUM_SQL" 2>/dev/null || echo "ERROR")
        echo "${table}_md5=${CKSUM}"
    done
} > "$COUNTS_FILE"

log "Counts sidecar: ${COUNTS_FILE}"

# ─── Step 1c: Write .schema sidecar ───

SCHEMA_FILE="${DUMP_FILE%.dump}.schema.gz"
docker exec -e PGPASSWORD="${POSTGRES_PASSWORD}" "$CONTAINER_NAME" \
    pg_dump --schema-only -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" 2>/dev/null \
    | gzip > "$SCHEMA_FILE"

log "Schema sidecar: ${SCHEMA_FILE}"

# ─── Step 2: pg_dump ───

log "Running pg_dump..."

docker exec -e PGPASSWORD="${POSTGRES_PASSWORD}" "$CONTAINER_NAME" \
    pg_dump -Fc -U "${POSTGRES_USER}" -d "${POSTGRES_DB}" \
    > "${DUMP_FILE}"

# ─── Step 3: Validate dump ───

DUMP_SIZE=$(stat -f%z "${DUMP_FILE}" 2>/dev/null || stat --printf="%s" "${DUMP_FILE}" 2>/dev/null)

if [ "$DUMP_SIZE" -lt "$MIN_DUMP_BYTES" ]; then
    log "ERROR: Dump file too small (${DUMP_SIZE} bytes < ${MIN_DUMP_BYTES}). Likely empty or corrupt."
    rm -f "${DUMP_FILE}" "${COUNTS_FILE}" "${SCHEMA_FILE}"
    exit 1
fi

# Verify dump is readable
if ! docker exec -i "$CONTAINER_NAME" pg_restore --list < "${DUMP_FILE}" > /dev/null 2>&1; then
    log "ERROR: pg_restore --list failed. Dump may be corrupt."
    rm -f "${DUMP_FILE}" "${COUNTS_FILE}" "${SCHEMA_FILE}"
    exit 1
fi

log "Dump validated: ${DUMP_FILE} ($(numfmt --to=iec "$DUMP_SIZE" 2>/dev/null || echo "${DUMP_SIZE} bytes"))"

# ─── Step 4: Sync to Box.com (if rclone configured) ───

SYNC_STATUS_FILE="${BACKUP_DIR}/.last_sync_status"

if command -v rclone &> /dev/null && rclone listremotes 2>/dev/null | grep -q "^box:"; then
    log "Copying to Box.com..."

    # DB backups (dump + sidecars)
    rclone_copy "db-backups-dump" "${DUMP_FILE}" "box:${BOX_FOLDER}/db-backups/"
    rclone_copy "db-backups-counts" "${COUNTS_FILE}" "box:${BOX_FOLDER}/db-backups/"
    rclone_copy "db-backups-schema" "${SCHEMA_FILE}" "box:${BOX_FOLDER}/db-backups/"

    # Extra sync directories
    for entry in "${EXTRA_SYNC_DIRS[@]+"${EXTRA_SYNC_DIRS[@]}"}"; do
        [ -z "$entry" ] && continue
        local_label=$(echo "$entry" | cut -d: -f1)
        local_path=$(echo "$entry" | cut -d: -f2)
        box_subfolder=$(echo "$entry" | cut -d: -f3-)
        # Split off any extra rclone args after the third colon-field
        IFS=' ' read -ra extra_args <<< "$(echo "$box_subfolder" | cut -d' ' -f2-)"
        box_subfolder=$(echo "$box_subfolder" | cut -d' ' -f1)
        if [ -d "$local_path" ]; then
            rclone_copy "$local_label" "$local_path" "box:${BOX_FOLDER}/${box_subfolder}/" "${extra_args[@]+"${extra_args[@]}"}"
        fi
    done

    if [ "$SYNC_FAILURES" -gt 0 ]; then
        log "Box.com copy completed with ${SYNC_FAILURES} failure(s)."
        echo "FAILED $(date '+%Y-%m-%d %H:%M:%S') sync_failures=${SYNC_FAILURES}" > "$SYNC_STATUS_FILE"
        send_alert \
            "[Mac mini] Box.com sync FAILED — ${PROJECT_NAME}" \
            "The ${PROJECT_NAME} backup completed locally but ${SYNC_FAILURES} rclone sync(s) failed at $(date '+%Y-%m-%d %H:%M:%S').

Check: rclone config reconnect box:

Recent log:
$(tail -20 "${LOG_FILE}")"
    else
        log "Box.com copy complete."
        echo "OK $(date '+%Y-%m-%d %H:%M:%S')" > "$SYNC_STATUS_FILE"
    fi
else
    log "SKIP: rclone not configured for box: — local backup only"
    echo "SKIPPED $(date '+%Y-%m-%d %H:%M:%S') rclone_not_configured" > "$SYNC_STATUS_FILE"
fi

# ─── Step 5: Clean up old local backups ───

DELETED=$(find "${BACKUP_DIR}" \( -name "*.dump" -o -name "*.counts" -o -name "*.schema.gz" \) -mtime +${LOCAL_RETENTION_DAYS} -delete -print 2>/dev/null | wc -l | tr -d ' ')
if [ "$DELETED" -gt 0 ]; then
    log "Cleaned up ${DELETED} local backup files older than ${LOCAL_RETENTION_DAYS} days."
fi

# ─── Step 6: Run consistency check (if available) ───

CONSISTENCY_SCRIPT="${SCRIPT_DIR}/consistency_check.sh"
if [ -x "$CONSISTENCY_SCRIPT" ]; then
    log "Running consistency check..."
    CONSISTENCY_OUTPUT=$("$CONSISTENCY_SCRIPT" 2>&1) || true
    if [ -n "$CONSISTENCY_OUTPUT" ]; then
        log "  $CONSISTENCY_OUTPUT"
    else
        log "  No issues found."
    fi
fi

# ─── Summary ───

TOTAL_DUMPS=$(find "${BACKUP_DIR}" -name "*.dump" | wc -l | tr -d ' ')
log "=== Backup complete ==="
log "  Dump: ${DUMP_FILE}"
log "  Size: ${DUMP_SIZE} bytes"
log "  ${HEALTH_CHECK_TABLE}: ${HEALTH_COUNT}"
log "  Local dumps retained: ${TOTAL_DUMPS}"
